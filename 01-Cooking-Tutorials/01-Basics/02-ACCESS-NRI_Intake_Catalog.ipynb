   "source": [
    "def select_region(ds):\n",
    "    ds = ds.sel(xt_ocean=slice(-230, -180), yt_ocean=slice(-50, -20))\n",
    "    return ds\n",
    "\n",
    "data_ic = catalog['01deg_jra55v13_ryf9091'].search(\n",
    "    variable='surface_temp', \n",
    "    frequency=\"1mon\"\n",
    ").to_dask(preprocess=select_region)\n",
    "data_ic"
   ]
  },
